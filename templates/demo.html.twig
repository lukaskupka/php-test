{% extends "base.html.twig" %}

{% block body %}
    <div class="product-grid">
    {% for item in data.getPagedItems %}
        <div class="product-wrapper">
            <div class="product-name">{{ item.name }}</div>
            <div class="product-price">{{ item.priceCents }}</div>
        </div>
    {% endfor %}
    </div>
    <nav aria-label="Product page navigation">
        <ul class="pagination">
            {% if data.getCurrentPage === 1 %}
                <li class="page-item disabled">
                    <a class="page-link">Previous</a>
                </li>
            {% else %}
                <li class="page-item">
                    <a class="page-link" href="{{ path('app_demo_index', {'page': 1}) }}">Previous</a>
                </li>
            {% endif %}
            {% for i in (1..data.getTotalPages) %}
                <li class="page-item">
                    <a
                        class="page-link {% if data.getCurrentPage === i %}active{% endif %}"
                        href="{{ path('app_demo_index', {'page': i}) }}"
                    >{{ i }}</a>
                </li>
            {% endfor %}
            {% if data.getCurrentPage === data.getTotalPages %}
                <li class="page-item disabled">
                    <a class="page-link">Next</a>
                </li>
            {% else %}
                <li class="page-item">
                    <a class="page-link" href="{{ path('app_demo_index', {'page': data.getCurrentPage + 1}) }}">Next</a>
                </li>
            {% endif %}
        </ul>
    </nav>
{% endblock %}
